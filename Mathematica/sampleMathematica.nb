Cell["First define all integration kernels", "Text",
 CellChangeTimes->{{3.968413520965967*^9, 3.968413558473812*^9}, {
  3.983444196698016*^9, 
  3.98344424977496*^9}},ExpressionUUID->"44684aa6-2d75-44e6-a1b0-\
ee985dad2248"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"defineKernel", "[", 
   RowBox[{"cot", ",", "Cot", ",", "1"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"defineKernel", "[", 
   RowBox[{"sq", ",", 
    RowBox[{
     RowBox[{"#", "^", "2"}], "&"}], ",", "0"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"defineKernel", "[", 
   RowBox[{"inv", ",", 
    RowBox[{
     RowBox[{"1", "/", "#"}], "&"}], ",", "1"}], "]"}], ";"}]}], "Input",
 CellChangeTimes->{{3.9834442810196753`*^9, 3.983444335862823*^9}, {
   3.9835310642076197`*^9, 3.983531073439947*^9}, 3.983531799411868*^9, {
   3.983531886245119*^9, 3.983531887435216*^9}, {3.986982306019815*^9, 
   3.986982306137991*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"dff2419f-df4b-4700-b179-9093184bead4"],

Cell["Then we define the expression we want to evaluate", "Text",
 CellChangeTimes->{{3.983444344443117*^9, 
  3.98344435356035*^9}},ExpressionUUID->"ad79bfbd-b0ba-4e48-a3a4-\
97bef0b4906a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"expr", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"IIntegral", "[", 
      RowBox[{"cot", ",", "sq", ",", "inv", ",", 
       RowBox[{"3", "/", "2"}]}], "]"}], ",", 
     RowBox[{"IIntegral", "[", 
      RowBox[{"cot", ",", "inv", ",", "sq", ",", 
       RowBox[{"3", "/", "2"}]}], "]"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9834442358737803`*^9, 3.98344423942214*^9}, {
  3.983444357396296*^9, 3.983444391582225*^9}, {3.9834444528159723`*^9, 
  3.983444469316421*^9}, {3.986982308369606*^9, 3.986982310926352*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"c50fc859-8cbe-4d11-81f2-e384ad54287d"],

Cell["\<\
Evaluating the integrals can then easily be performed by the following code\
\>", "Text",
 CellChangeTimes->{{3.9834444146333733`*^9, 3.983444426499296*^9}, {
  3.983444471875958*^9, 
  3.9834444731446247`*^9}},ExpressionUUID->"d7a76bb7-0b80-4610-8738-\
831b10c38674"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"computeIIntegrals", "[", "expr", "]"}]], "Input",
 CellChangeTimes->{{3.983530886178521*^9, 3.983530908016412*^9}, {
  3.9835311154236393`*^9, 3.983531115703521*^9}, {3.983531873525819*^9, 
  3.983531876114056*^9}, {3.986374557571062*^9, 3.986374567443179*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"3f1bcf38-900d-455f-a8cd-e4faf223ff43"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "0.15070248168046368`"}], ",", 
   RowBox[{"-", "0.06480709217824292`"}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.9835318173136063`*^9, 3.983531880476302*^9, 3.986373773048064*^9, 
   3.986374408375246*^9, 3.986374491481202*^9, 3.9863745626585493`*^9, {
   3.9863746376131573`*^9, 3.986374689282352*^9}, 3.986982313213862*^9, 
   3.988103282399301*^9, 3.988103369621438*^9, 3.988103574273364*^9, 
   3.988103618758634*^9, 3.989304232583659*^9, 3.9893042646183853`*^9, 
   3.989459031509694*^9},
 CellLabel->"Out[6]=",ExpressionUUID->"e3a2c5fb-f564-4f82-87fa-2dc04180408d"]
}, Open  ]],

Cell["We can use a different algorithm", "Text",
 CellChangeTimes->{{3.968413561069365*^9, 3.968413573953183*^9}, {
  3.983444448612196*^9, 3.983444493468904*^9}, {3.988103292714916*^9, 
  3.988103292886903*^9}, {3.9881036195776463`*^9, 
  3.988103620187543*^9}},ExpressionUUID->"bf2ef0e7-74d5-4c5a-a1e3-\
d6a5af7bbacb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"computeIIntegrals", "[", 
  RowBox[{"expr", ",", 
   RowBox[{"integrationAlgorithm", "->", "plainIntegrate"}]}], "]"}]], "Input",\

 CellChangeTimes->{{3.96831801884289*^9, 3.968318030840288*^9}, {
  3.9684080106372347`*^9, 3.968408035322013*^9}, {3.96840861284122*^9, 
  3.9684086203419743`*^9}, {3.983444502923831*^9, 3.983444553023199*^9}, {
  3.98810329479524*^9, 3.9881032962385197`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"8afae542-7ab6-4e74-90dd-384e453f6612"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "0.1507024354835412`"}], ",", 
   RowBox[{"-", "0.06480713115829388`"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.968318027647499*^9, 3.968318031551136*^9}, 
   3.968407948263035*^9, 3.9684080474349833`*^9, {3.96840861563095*^9, 
   3.9684086206915407`*^9}, 3.979812041418401*^9, {3.983444537599286*^9, 
   3.983444553313829*^9}, {3.986374664112237*^9, 3.9863746892962914`*^9}, 
   3.986982349216996*^9, 3.988103296607565*^9, 3.988103372068256*^9, 
   3.988103621430448*^9, 3.9893042326949453`*^9, 3.989304264652788*^9, 
   3.989459031579748*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"0a961d94-0f2b-4057-a29c-6942052bfcd1"]
}, Open  ]],

Cell["Just perform the regularization", "Text",
 CellChangeTimes->{{3.968413580081818*^9, 3.968413589527965*^9}, {
  3.983444602924056*^9, 3.9834446077733603`*^9}, {3.986982349765431*^9, 
  3.986982350392631*^9}},ExpressionUUID->"42154d20-a647-4ea4-a5c0-\
be74c3cdc4f4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"regular", "=", 
  RowBox[{"regulateExpression", "[", "expr", "]"}]}]], "Input",
 CellChangeTimes->{{3.983444608891201*^9, 3.9834446612143993`*^9}, {
  3.9869823228470297`*^9, 3.986982352478533*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"5f8aa70b-a4b8-444e-973e-16d59680f2f1"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"IIntegral", "[", 
      RowBox[{"sq", ",", "inv", ",", 
       RowBox[{"pole", "[", "cot", "]"}], ",", 
       FractionBox["3", "2"]}], "]"}]}], "-", 
    RowBox[{"IIntegral", "[", 
     RowBox[{"sq", ",", 
      RowBox[{"pole", "[", "cot", "]"}], ",", "inv", ",", 
      FractionBox["3", "2"]}], "]"}], "+", 
    RowBox[{"IIntegral", "[", 
     RowBox[{
      RowBox[{"regulated", "[", "cot", "]"}], ",", "sq", ",", "inv", ",", 
      FractionBox["3", "2"]}], "]"}], "+", 
    RowBox[{"IIntegral", "[", 
     RowBox[{
      RowBox[{"regulated", "[", "inv", "]"}], ",", 
      RowBox[{"pole", "[", "sq", "]"}], ",", 
      RowBox[{"pole", "[", "cot", "]"}], ",", 
      FractionBox["3", "2"]}], "]"}], "+", 
    RowBox[{
     RowBox[{"IIntegral", "[", 
      RowBox[{"sq", ",", "inv", ",", 
       FractionBox["3", "2"]}], "]"}], " ", 
     RowBox[{"Log", "[", 
      FractionBox["3", "2"], "]"}]}]}], ",", 
   RowBox[{
    RowBox[{"IIntegral", "[", 
     RowBox[{"sq", ",", 
      RowBox[{"pole", "[", "inv", "]"}], ",", 
      RowBox[{"pole", "[", "cot", "]"}], ",", 
      FractionBox["3", "2"]}], "]"}], "+", 
    RowBox[{"IIntegral", "[", 
     RowBox[{
      RowBox[{"regulated", "[", "cot", "]"}], ",", "inv", ",", "sq", ",", 
      FractionBox["3", "2"]}], "]"}], "-", 
    RowBox[{"IIntegral", "[", 
     RowBox[{
      RowBox[{"regulated", "[", "inv", "]"}], ",", "sq", ",", 
      RowBox[{"pole", "[", "cot", "]"}], ",", 
      FractionBox["3", "2"]}], "]"}], "-", 
    RowBox[{"IIntegral", "[", 
     RowBox[{
      RowBox[{"regulated", "[", "inv", "]"}], ",", 
      RowBox[{"pole", "[", "cot", "]"}], ",", "sq", ",", 
      FractionBox["3", "2"]}], "]"}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"IIntegral", "[", 
         RowBox[{"sq", ",", 
          RowBox[{"pole", "[", "inv", "]"}], ",", 
          FractionBox["3", "2"]}], "]"}]}], "+", 
       RowBox[{"IIntegral", "[", 
        RowBox[{
         RowBox[{"regulated", "[", "inv", "]"}], ",", "sq", ",", 
         FractionBox["3", "2"]}], "]"}]}], ")"}], " ", 
     RowBox[{"Log", "[", 
      FractionBox["3", "2"], "]"}]}], "+", 
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"IIntegral", "[", 
      RowBox[{"sq", ",", 
       FractionBox["3", "2"]}], "]"}], " ", 
     SuperscriptBox[
      RowBox[{"Log", "[", 
       FractionBox["3", "2"], "]"}], "2"]}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.9834446136106653`*^9, 3.9834446616780252`*^9}, 
   3.986374689309593*^9, 3.986982352923787*^9, 3.988103299672678*^9, 
   3.988103373209243*^9, 3.988103622764617*^9, 3.989304232732937*^9, 
   3.9893042646741667`*^9, 3.989459031616314*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"a80eee2c-29c0-40e4-a784-8efb217f9db7"]
}, Open  ]],

Cell["\<\
We can remove all trivially vanishing integrals and afterwards evaluate the \
integral\
\>", "Text",
 CellChangeTimes->{{3.983444717467081*^9, 3.9834447368265867`*^9}, {
  3.9834447675207577`*^9, 3.983444775811923*^9}, {3.9834448438914127`*^9, 
  3.9834448513516407`*^9}},ExpressionUUID->"fea94eca-3d74-45f4-8b2e-\
5dab397f9b16"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"simplified", "=", 
  RowBox[{"regular", "/.", 
   RowBox[{
    RowBox[{"IIntegral", "[", 
     RowBox[{
      RowBox[{"regulated", "[", "inv", "]"}], ",", "___"}], "]"}], ":>", 
    "0"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"computeIIntegrals", "[", "simplified", "]"}]}], "Input",
 CellChangeTimes->{{3.983444808047024*^9, 3.983444863738179*^9}, {
  3.983444900351245*^9, 3.983444905136712*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"c20ec341-6d94-4687-be5f-2984b03bf5bb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     RowBox[{"IIntegral", "[", 
      RowBox[{"sq", ",", "inv", ",", 
       RowBox[{"pole", "[", "cot", "]"}], ",", 
       FractionBox["3", "2"]}], "]"}]}], "-", 
    RowBox[{"IIntegral", "[", 
     RowBox[{"sq", ",", 
      RowBox[{"pole", "[", "cot", "]"}], ",", "inv", ",", 
      FractionBox["3", "2"]}], "]"}], "+", 
    RowBox[{"IIntegral", "[", 
     RowBox[{
      RowBox[{"regulated", "[", "cot", "]"}], ",", "sq", ",", "inv", ",", 
      FractionBox["3", "2"]}], "]"}], "+", 
    RowBox[{
     RowBox[{"IIntegral", "[", 
      RowBox[{"sq", ",", "inv", ",", 
       FractionBox["3", "2"]}], "]"}], " ", 
     RowBox[{"Log", "[", 
      FractionBox["3", "2"], "]"}]}]}], ",", 
   RowBox[{
    RowBox[{"IIntegral", "[", 
     RowBox[{"sq", ",", 
      RowBox[{"pole", "[", "inv", "]"}], ",", 
      RowBox[{"pole", "[", "cot", "]"}], ",", 
      FractionBox["3", "2"]}], "]"}], "+", 
    RowBox[{"IIntegral", "[", 
     RowBox[{
      RowBox[{"regulated", "[", "cot", "]"}], ",", "inv", ",", "sq", ",", 
      FractionBox["3", "2"]}], "]"}], "-", 
    RowBox[{
     RowBox[{"IIntegral", "[", 
      RowBox[{"sq", ",", 
       RowBox[{"pole", "[", "inv", "]"}], ",", 
       FractionBox["3", "2"]}], "]"}], " ", 
     RowBox[{"Log", "[", 
      FractionBox["3", "2"], "]"}]}], "+", 
    RowBox[{
     FractionBox["1", "2"], " ", 
     RowBox[{"IIntegral", "[", 
      RowBox[{"sq", ",", 
       FractionBox["3", "2"]}], "]"}], " ", 
     SuperscriptBox[
      RowBox[{"Log", "[", 
       FractionBox["3", "2"], "]"}], "2"]}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.983444812385234*^9, 3.983444863963854*^9}, 
   3.983444905557433*^9, 3.986374689326058*^9, 3.986982374753331*^9, 
   3.988103304722032*^9, 3.988103374548373*^9, 3.988103625733121*^9, 
   3.98930423277345*^9, 3.989304264700933*^9, 3.989459031653948*^9},
 CellLabel->"Out[9]=",ExpressionUUID->"a14daa06-0ee7-4eca-8764-305775714adb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", "0.15070257791153419`"}], ",", 
   RowBox[{"-", "0.06480704804912159`"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.983444812385234*^9, 3.983444863963854*^9}, 
   3.983444905557433*^9, 3.986374689326058*^9, 3.986982374753331*^9, 
   3.988103304722032*^9, 3.988103374548373*^9, 3.988103625733121*^9, 
   3.98930423277345*^9, 3.989304264700933*^9, 3.989459031655901*^9},
 CellLabel->"Out[10]=",ExpressionUUID->"7da0dc93-1e52-444f-af94-07ce8a58003a"]
}, Open  ]],

Cell["The library supports arbitrary precision calculations", "Text",
 CellChangeTimes->{{3.968413615848198*^9, 3.968413625389742*^9}, {
  3.983444873482944*^9, 3.983444884104218*^9}, {3.983444976105*^9, 
  3.98344497771929*^9}},ExpressionUUID->"22d237e1-6db4-4788-ae44-\
921087b30f42"],

Cell[CellGroupData[{

