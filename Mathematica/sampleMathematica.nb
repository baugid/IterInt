Cell["We can evaluate integrals with parameters", "Text",
 CellChangeTimes->{{3.988103404619172*^9, 3.9881034114095*^9}, 
   3.988103633388606*^9},ExpressionUUID->"a6a55d82-fb8c-4a09-8710-\
5539971f42da"],

Cell[BoxData[
 RowBox[{
  RowBox[{"defineKernel", "[", 
   RowBox[{"shifted", ",", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"#", "-", "a"}]], "&"}], ",", 
    RowBox[{"KroneckerDelta", "[", 
     RowBox[{"a", ",", "0"}], "]"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.988103414455386*^9, 3.988103441347866*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"94a8c59f-7028-44da-83e5-2a5429f50d4c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"computeIIntegrals", "[", 
  RowBox[{
   RowBox[{"IIntegral", "[", 
    RowBox[{"shifted", ",", 
     RowBox[{"a", "/", "2"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"a", "->", "2"}], "}"}], ",", 
   RowBox[{"integrationAlgorithm", "->", "plainIntegrate"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"computeIIntegrals", "[", 
  RowBox[{
   RowBox[{"IIntegral", "[", 
    RowBox[{"shifted", ",", "3"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"a", "->", "0"}], "}"}], ",", 
   RowBox[{"integrationAlgorithm", "->", "plainIntegrate"}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.988103444822694*^9, 3.988103472168449*^9}, {
