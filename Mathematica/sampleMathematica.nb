 RowBox[{"computeIIntegrals", "[", 
  RowBox[{"simplified", ",", " ", 
   RowBox[{"WorkingPrecision", "->", "50"}], ",", 
   RowBox[{"PrecisionGoal", "->", "30"}]}], "]"}]], "Input",
